#!/bin/bash
# © 2025 James D. Fischer
#
# <help_begin>
# NAME
#   make-vars - displays information about makefile variables
#
# SYNOPSIS
#   make-vars [OPTIONS] [pattern [pattern [...]]]
#   make-vars --help
#
# DESCRIPTION
#   By default, make-vars invokes `make --print-data-base --dry-run' to
#   produce a listing that provides
#   * The rules, variable names, and variable values provided by the make
#     program itself, and
#   * The rules, variable names, and variable values that are defined via
#     the local makefile.
#
#   The patterns are regular expression patterns.  If one or more patterns
#   are specified, the patterns filter the output.
#
# OPTIONS
#   --color[=WHEN], --colour[=WHEN]
#       Controls whether the search results are colorized or not. If this
#       option is not used or if WHEN is not specified, the search results
#       are colorized by default. WHEN is either 'always' or 'never'.
#
#   -d, --defaults
#       The printed listing shows the default values for make's built-in
#       variables and rules. The output does not show any environment
#       variables that might affect make's output, and it does not show any
#       make variables or rules found in user-defined makefile(s).
#       (NOTE: This option overrides option -e.  If options -d and -e are
#       both used, the -e option is ignored.)
#
#   -f file, --file=file, --makefile=file
#       Use `file' as the makefile.
#
#   -h, --help
#       Prints this help message.
#
#   -e, --empty-environment
#       Invokes make in an empty environment.  This is useful if you want
#       the search results to include variables that are defined within a
#       Makefile, and exclude variables that are defined by the host's
#       environment.
#
#   -v, --only-variables
#       If a search pattern is provided, the output is filtered to show
#       only variable values. Otherwise, this option is ignored.
#
#    --Wundefined-variables
#       Prints a listing of warnings about undefined variables, if any. No
#       other output is produced.  This option is useful if you want to
#       produce a listing of undefined variables and nothing else.
#
#   --Wno-undefined-variables
#       By default, make-vars prints warnings about undefined variables in
#       the makefile. This option silences those warnings.
#
# <help_end>
#
set -eu
clear

# shellcheck disable=SC1091
source /usr/local/libexec/eceugl-utils/trace

SCRIPT_NAME="$(/usr/bin/basename "${BASH_SOURCE[0]}")"
declare -r SCRIPT_NAME


## Program paths
# [Note 1: Use Bash's builtin `echo' and `printf', and not their coreutils
# counterparts /usr/bin/echo and /usr/bin/printf.  --end note]
declare -r CAT=/usr/bin/cat
declare -r ENV=/usr/bin/env
declare -r GETOPT=/usr/bin/getopt
declare -r GREP=/usr/bin/grep
declare -r PAGER=/usr/bin/less
declare -r MAKE=/usr/bin/make
declare -r RM=/usr/bin/rm
declare -r SED=/usr/bin/sed
declare -r SORT=/usr/bin/sort
declare -r UNIQ=/usr/bin/uniq


#==========================================================================
# catch STDOUT STDERR cmd [args...]
# Captures simultaneously into variables STDOUT and STDERR the output sent
# to stdout and stderr, respectively, by the command `cmd'.
#
# I'm assuming the copyright holder for this code is the author of this
# post on StackOverflow.com: https://stackoverflow.com/a/41069638/5051940
#==========================================================================

function catch()
{
set +e
    eval "$({
    __2="$(
      { __1="$("${@:3}")"; } 2>&1;
      ret=$?;
      printf '%q=%q\n' "$1" "$__1" >&2;
      exit $ret
      )"
    ret=$?;
    printf '%s=%q\n' "$2" "$__2" >&2;
    printf 'return %q\n' "$ret" >&2;
    } 2>&1 )";
set -e
}


#==========================================================================
# ParseTheCommandLine() "$@"
#==========================================================================

function ParseTheCommandLine()
{
    # Parameter values for `lopts' and `sopts'
    # X   no operand
    # X:  required operand--e.g., -X required_value, --ex=required_value
    # X:: optional operand--e.g., -X  =OR=  -X value
    local lopts="color:: colour:: defaults file: help empty-environment makefile: only-variables Wundefined-variables Wno-undefined-variables"
    local sopts="d f: h i v"
    local getopt_exit_code
    local getopt_stdout
    local getopt_stderr

set +e
    catch getopt_stdout getopt_stderr \
        "${GETOPT}" -o "${sopts}" -l "${lopts}" -a -n$-1 -s bash -- "$@"
    getopt_exit_code=$?
set -e

    if [[ "${getopt_exit_code}" -ne 0 ]]; then
        >&2 echo "${getopt_stderr[@]}"
        exit "${getopt_exit_code}"
    fi

    eval set -- "${getopt_stdout}"

    while [[ $# -gt 0 ]]
    do
        case "$1" in
            --color|--colour) 
                if [[ -z "$2" || "$2" =~ ^- ]]; then
                    # --color
                    cloColorOutput='always'  # the default
                else
                    # --color=WHEN
                    if [[ "$2" == "always" ]]; then
                        cloColorOutput='always'
                    else
                        cloColorOutput='never'
                    fi
                    shift
                fi
                ;;
            -d|--defaults) cloDefaults=true ;;
            -f|--file|--makefile) cloMakefile="${2}"; shift ;;
            -h|--help) cloHelpRequested=true ;;
            -e|--empty-environment) cloIgnoreEnvironment=true ;;
            -v|--only-variables) cloOnlyVariables=true ;;
            --Wundefined-variables) cloWarnUndefinedVariables=true ;;
            --Wno-undefined-variables) cloNoWarnUndefinedVariables=true ;;
            --) # Process the positional parameters
                while [[ $# -gt 1 ]]
                do
                    shift
                    cloSearchPatterns+=("$1")
                done
                ;;
        esac
        shift
    done
}


#==========================================================================
# Function: print_banner
#
# Description:
#   Prints a thick horizontal rule, followed on the next line by the
#   batter_title text, followed on the next line by a thin horizontal rule.
#
# Parameters:
#   $1 banner_title (string, required): The banner's title string
#   $2 hr_char (string, optional): The character to be used to draw the
#   banner's horizontal rules/lines.
#
# Modifies Global Variables: None.
#
# Creates/Modifies Files: None.
#
# Returns: None.
#==========================================================================
function print_banner()
{
    local -r banner_title="$1"
    local -r hr_char="${2:-=}"
    print_horizontal_rule "${hr_char}"
    echo " ${banner_title}"
    print_horizontal_rule "${hr_char}"
}


#==========================================================================
# Function: print_horizontal_rule
#
# Description: Prints a horizontal rule (a line) to stdout.
#
# Parameters:
#   $1 rule_character (character, optional):
#   $2 rule_length (integer, optional): (default: 75)
#
# Returns:
#   None.
#==========================================================================

function print_horizontal_rule()
{
    local -r rule_character="${1:-'-'}"
    local -r -i rule_length=${2:-75}
    local -i i
    local horizontal_rule

    horizontal_rule=
    for (( i=0; i<rule_length; ++i )); do
        horizontal_rule+="$rule_character"
    done
    if [ -n "$horizontal_rule" ]; then
        echo "$horizontal_rule"
    fi
}


#==========================================================================
#  main
#==========================================================================

cloColorOutput='always'
cloDefaults=false
cloHelpRequested=false
cloIgnoreEnvironment=false
cloMakefile=
cloNoWarnUndefinedVariables=false
cloOnlyVariables=false
cloSearchPatterns=()
cloWarnUndefinedVariables=false

ParseTheCommandLine "$@"

#--------------------------------------------------------------------------
#  If the user requested help, display the help information and exit.
#--------------------------------------------------------------------------

if $cloHelpRequested; then
    export LESS="--quit-if-one-screen --prompt=\ Help for ${SCRIPT_NAME}\: ?ltline %lt?L/%L.:byte %bB?s/%s..?e (END):?pB %pB\%.. (press h for help or q to quit)\ "
    "${SED}" -n -e '/help_begin/,/help_end/{ /help_begin/d; /help_end/q; s/#\( \)\?//; p }' "$0" \
        | "${PAGER}"
    exit 0
fi


#--------------------------------------------------------------------------
# Create a temporary file and configure this script to automatically delete
# that file when the script exits.
#--------------------------------------------------------------------------

TMPFILE="$(/usr/bin/mktemp)"
declare -r TMPFILE

# Automatically delete TMPFILE when this script exits.
trap '"${RM}" -f -- "${TMPFILE}"' EXIT


#--------------------------------------------------------------------------
# Perform a reconnaissance make (a.k.a., a "dry run" make) and redirect
# make's output into the TMPFILE.
#--------------------------------------------------------------------------

make_flags=(
    --recon
    --keep-going
    --print-data-base
    --warn-undefined-variables
    )
if [ -n "$cloMakefile" ]; then
    make_flags+=( --file="$cloMakefile" )
fi

set +e
if $cloDefaults; then

    # Make's reconnaissance output is filtered as follows:
    #   * Include make's built-in variables and rules
    #   * Exclude the Makefile's variables and rules, and
    #   * Exclude variables defined by the user's environment
    "${ENV}" -i "${MAKE}" --makefile=/dev/null "${make_flags[@]}" >& "${TMPFILE}"

elif $cloIgnoreEnvironment; then

    # Make's reconnaissance output is filtered as follows:
    #   * Include make's built-in variables and rules
    #   * Include the Makefile's variables and rules, and
    #   * Exclude variables defined by the user's environment
    "${ENV}" -i "${MAKE}" "${make_flags[@]}" >& "${TMPFILE}"
else

    # This is the default case.
    # Make's reconnaissance output is filtered as follows:
    #   * Include make's built-in variables and rules
    #   * Include the Makefile's variables and rules, and
    #   * Include variables defined by the user's environment
    "${MAKE}" "${make_flags[@]}" >& "${TMPFILE}"

fi
set -e


#--------------------------------------------------------------------------
# Remove any ANSI escape codes (e.g., color codes) from the text in file 
# TMPFILE.  See also:
# [1] https://unix.stackexchange.com/a/55547/121145
# [2] https://stackoverflow.com/q/17998978/5051940
#--------------------------------------------------------------------------

"${SED}" -i -e 's/\x1B\[[0-9;]*[JKmsu]//g' "${TMPFILE}"


#--------------------------------------------------------------------------
# Print the search results.
# If option --Wundefined-variables was used, ignore this section.
#--------------------------------------------------------------------------

if ! $cloWarnUndefinedVariables; then
    # If make-vars was invoked without a search pattern, print everything.
    if [ ${#cloSearchPatterns[@]} -eq 0 ]; then
        # Print everything
        "${CAT}" "${TMPFILE}"
    else
        # The user specified one or more search patterns when they invoked
        # make-vars. For each search pattern, print the lines in TMPFILE
        # that match that search pattern.
        for search_pattern in "${cloSearchPatterns[@]}"; do

            print_banner "PATTERN: |${search_pattern}|"

            # If the search pattern contains '#', ':', or '=', use the
            # search pattern "as is".  Otherwise, assume the user is
            # searching for a variable name and modify the search pattern
            # to find variable names.
            case $search_pattern in
                *\#*|*:*|*=*) variable_search_pattern="$search_pattern";;
                *) variable_search_pattern="^[^#:=]*${search_pattern}[^#:=]*:\?=" ;;
            esac

            # List the variable definitions first, and sorted by name.
            echo "VARIABLES"
            print_horizontal_rule '-'
            "${GREP}" --color=never "${variable_search_pattern}" "${TMPFILE}" \
                | "${GREP}" --color="${cloColorOutput}" "${search_pattern}" \
                | "${SORT}"

            if ! $cloOnlyVariables; then
                echo
                print_banner "OTHER MATCHES" '-'
                # List other occurrences of PATTERN that aren't variable
                # definitions (e.g., rules and recipes).
                "${GREP}" -v --color=never "${variable_search_pattern}" "${TMPFILE}" \
                    | "${GREP}" --color="${cloColorOutput}" "${search_pattern}" || true
            fi

        done
    fi
fi


#--------------------------------------------------------------------------
# If option --Wno-undefined-variables was used, ignore this section.
#--------------------------------------------------------------------------

if ! $cloNoWarnUndefinedVariables; then
    print_banner "UNDEFINED VARIABLES"
    set -o pipefail
    if ! "${GREP}" ' warning: undefined variable ' "${TMPFILE}" | "${SORT}" | "${UNIQ}"
    then
        echo "There are no undefined variables."
    fi
    set +o pipefail
fi
